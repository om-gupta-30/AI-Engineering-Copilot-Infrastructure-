# ─────────────────────────────────────────────────────────────────────────────
# AI Copilot Infra — environment variable reference
# Copy this file to .env and fill in your values. Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=AI Copilot Infra
APP_ENV=development          # development | staging | production
APP_VERSION=0.1.0
DEBUG=true

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── MCP Server ────────────────────────────────────────────────────────────────
MCP_BASE_URL=http://mcp:8100
MCP_TIMEOUT_SECONDS=30.0

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.2
OPENAI_MAX_TOKENS=2048
OPENAI_TIMEOUT_SECONDS=60.0

# ── Context7 ──────────────────────────────────────────────────────────────────
CONTEXT7_BASE_URL=https://context7.example.com
CONTEXT7_API_KEY=
CONTEXT7_TIMEOUT_SECONDS=10.0

# ── Langfuse (optional — activate when ready) ─────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json              # json | text
